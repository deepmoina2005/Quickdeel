generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ListingCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
  SOLD
}

enum ReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

model User {
  id               Int                  @id @default(autoincrement())
  name             String
  email            String               @unique
  password         String
  avatar           String?
  phone            String?
  about            String?              @db.Text
  contactEmail     String?
  role             Role                 @default(USER)
  isVerifiedSeller Boolean              @default(false)
  isEliteSeller    Boolean              @default(false)
  refreshToken     String?              @db.Text
  resetToken       String?              @db.Text
  resetTokenExpiry DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  listings         Listing[]
  favorites        Favorite[]
  sentMessages     Message[]
  sentOffers       Offer[]
  buyerChats       Conversation[]       @relation("BuyerConversations")
  sellerChats      Conversation[]       @relation("SellerConversations")
  reviewsGiven     Review[]             @relation("ReviewsGiven")
  sellerReviews    Review[]             @relation("SellerReviews")
  reports          Report[]             @relation("ReportsCreated")
  reportedBy       Report[]             @relation("ReportedUser")
  notifications    Notification[]
  following        Follow[]             @relation("UserFollowing")
  followers        Follow[]             @relation("UserFollowers")
  hiddenChats      ConversationHidden[]

  @@index([role])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listings  Listing[]
}

model Listing {
  id            Int              @id @default(autoincrement())
  title         String
  description   String           @db.Text
  price         Decimal          @db.Decimal(12, 2)
  condition     ListingCondition
  status        ListingStatus    @default(APPROVED)
  location      String
  country       String?
  state         String?
  city          String?
  userId        Int
  categoryId    Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category         @relation(fields: [categoryId], references: [id])
  images        ListingImage[]
  favorites     Favorite[]
  reports       Report[]
  conversations Conversation[]

  @@index([categoryId])
  @@index([userId])
  @@index([status])
  @@index([location])
  @@index([country])
  @@index([state])
  @@index([city])
}

model ListingImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  listingId Int
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  listingId Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id        Int                  @id @default(autoincrement())
  buyerId   Int
  sellerId  Int
  listingId Int?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  buyer     User                 @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    User                 @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  listing   Listing?             @relation(fields: [listingId], references: [id], onDelete: Cascade)
  messages  Message[]
  offers    Offer[]
  hiddenFor ConversationHidden[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
}

model ConversationHidden {
  id             Int          @id @default(autoincrement())
  conversationId Int
  userId         Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  message        String       @db.Text
  type           String       @default("TEXT")
  imageUrl       String?
  locationLat    Float?
  locationLng    Float?
  locationLabel  String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Offer {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  amount         Decimal      @db.Decimal(12, 2)
  status         String       @default("SENT")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Review {
  id         Int      @id @default(autoincrement())
  reviewerId Int
  sellerId   Int
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  seller     User     @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, sellerId])
}

model Report {
  id             Int          @id @default(autoincrement())
  userId         Int
  listingId      Int?
  reportedUserId Int?
  reason         String       @db.Text
  status         ReportStatus @default(OPEN)
  createdAt      DateTime     @default(now())
  user           User         @relation("ReportsCreated", fields: [userId], references: [id], onDelete: Cascade)
  listing        Listing?     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}